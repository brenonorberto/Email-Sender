# EMAIL_USER=
# EMAIL_PASS=
# SMTP_SERVICE=gmail
# ROOT_FOLDER=./empresas
# SEND_INTERVAL=600000

# =======================================================
# EMAIL SENDER — Configuração de Ambiente
# =======================================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# =======================================================

# --- Credenciais de Email ---

# Seu endereço Gmail
EMAIL_USER=seu@gmail.com

# OBRIGATÓRIO: usar App Password, NÃO a senha normal do Gmail
# Como gerar:
#   1. Ative 2FA: https://myaccount.google.com/security
#   2. Gere a senha: https://myaccount.google.com/apppasswords
#   3. Cole os 16 caracteres aqui (com ou sem espaços)
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Provedor SMTP — use 'gmail' para Gmail
# Não é necessário configurar SMTP_HOST/PORT ao usar SMTP_SERVICE=gmail
SMTP_SERVICE=gmail

# --- Configuração de Pastas ---

# Pasta raiz onde ficam as subpastas de cada empresa
ROOT_FOLDER=./empresas

# --- Configuração de Envio ---

# Intervalo entre cada verificação da fila (em milissegundos)
# 60000  = 1 minuto
# 600000 = 10 minutos (padrão)
# SEND_INTERVAL=600000 # 10 minutos em milissegundos
SEND_INTERVAL=600000

# Número máximo de tentativas de envio antes de mover para ERRO/
MAX_RETRIES=3

# --- Assinatura (opcional) ---
# Caminho para uma imagem que será embutida no email
SIGNATURE_IMAGE_PATH=./config/assinatura.png

# Texto que aparecerá abaixo da mensagem (use \n para quebra de linha)
SIGNATURE_TEXT="Atenciosamente,\nSeu Nome"
